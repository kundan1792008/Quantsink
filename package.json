{
  "name": "quantsink",
  "version": "1.0.0",
  "description": "Quantsink unified frontend and biometric API workspace",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "next dev",
    "dev:backend": "ts-node-dev --respawn --transpile-only --project tsconfig.server.json src/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "next build",
    "build:backend": "tsc -p tsconfig.server.json",
    "start": "npm run start:frontend",
    "start:frontend": "next start",
    "start:backend": "node dist/index.js",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"src/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "framer-motion": "latest",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.5.14",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.14",
    "jest": "^29.7.0",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.4.5"
  }
}
