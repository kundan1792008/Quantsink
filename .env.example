# Required
DATABASE_URL=postgresql://quantsink:password@localhost:5432/quantsink

# Quantmail Biometric SSO — shared JWT secret (RS256 public key in production)
QUANTMAIL_JWT_SECRET=change-me-in-production

# Optional — URL of the Quantmail shadow-inbox spam filter API
QUANTMAIL_FILTER_API_URL=https://api.quantmail.example.com/v1/filter

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
